modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AIå‰¯æ¥­ă‚·ă‚¹ăƒ†ăƒ  (main.py)"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AIå‰¯æ¥­ă‚·ă‚¹ăƒ†ăƒ  (Streamlit)"

[[workflows.workflow]]
name = "AIå‰¯æ¥­ă‚·ă‚¹ăƒ†ăƒ  (main.py)"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd ai_side_biz && python main.py all"

[[workflows.workflow]]
name = "AIå‰¯æ¥­ă‚·ă‚¹ăƒ†ăƒ  (Streamlit)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd ai_side_biz && streamlit run app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
