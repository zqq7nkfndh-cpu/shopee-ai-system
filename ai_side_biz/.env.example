# このファイルを .env にコピーして値を入れてください。
# .env は絶対にGitにコミットしない・公開しないこと。

# 楽天ウェブサービス(https://webservice.rakuten.co.jp/ でアプリID発行)
RAKUTEN_APP_ID=your_rakuten_app_id_here
RAKUTEN_AFFILIATE_ID=your_rakuten_affiliate_id_optional

# 任意: 文章生成の質を上げたい場合(未設定でもテンプレートベースで動作します)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Shopee利益計算用の為替レート(円/ドル)。運用のたびに最新レートに更新推奨。
JPY_PER_USD=150
